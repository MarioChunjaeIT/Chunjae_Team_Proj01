<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cornedu.api.auth.mapper.TokenBlacklistMapper">

    <insert id="insert">
        INSERT INTO tbl_token_blacklist (token, expires_at) VALUES (#{token}, #{expiresAt})
    </insert>

    <select id="countByToken" resultType="long">
        SELECT COUNT(*) FROM tbl_token_blacklist WHERE token = #{token}
    </select>

    <delete id="deleteExpired">
        DELETE FROM tbl_token_blacklist WHERE expires_at &lt; NOW()
    </delete>

</mapper>
